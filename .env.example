# App
APP_NAME="AI 电商运营 Agent"
APP_ENV="development"
APP_URL="http://localhost:3000"

# Auth
AUTH_SECRET="replace-with-local-dev-secret"
DEMO_USER_EMAIL="demo@example.com"

# Database
POSTGRES_USER="replace-with-local-user"
POSTGRES_PASSWORD="replace-with-local-password"
POSTGRES_DB="a_group_ecommerce_ops_agent"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://replace-with-local-user:replace-with-local-password@localhost:5432/a_group_ecommerce_ops_agent?schema=public"

# Object storage
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# AI provider
AI_PROVIDER="openai"
AI_API_KEY=""
AI_TEXT_MODEL=""
AI_IMAGE_MODEL=""

# Image generation provider placeholders. Do not expose these values in the browser.
IMAGE_GENERATION_PROVIDER=""
IMAGE_GENERATION_API_KEY=""
IMAGE_GENERATION_MODEL=""

# Job scheduling
JOB_QUEUE_PROVIDER="postgres"

# Feishu integration, optional and workspace-scoped.
# Never commit real App Secret, encrypt key, verification token, chat ID, doc ID, or bitable ID.
FEISHU_APP_ID="cli_aaea1dbb6ee1dd10"
FEISHU_APP_SECRET=""
FEISHU_ENCRYPT_KEY=""
FEISHU_VERIFICATION_TOKEN=""
FEISHU_DEFAULT_CHAT_ID=""
FEISHU_RESULT_DOCUMENT_ID=""
FEISHU_RESULT_BITABLE_ID=""
# Local testing: use long connection in Feishu event subscription first.
# Run with: pnpm run feishu:worker
FEISHU_EVENT_SUBSCRIPTION_MODE="long_connection"

# Optional: make the Feishu worker answer from a local real store table instead of demo data.
# CSV, TSV, Markdown table files, copied spreadsheet text, and recent two-week order details are all supported.
ECOMMERCE_STORE_NAME=""
ECOMMERCE_PLATFORM=""
ECOMMERCE_MARKET=""
ECOMMERCE_CATEGORY=""
ECOMMERCE_GOAL="同时看销量、利润、广告回本、库存风险、退款/退货和竞品压力"
ECOMMERCE_WEEKLY_METRICS_CSV="data/samples/aurora-cup-weekly-metrics.csv"
ECOMMERCE_COMPETITORS_CSV="data/samples/aurora-cup-competitors.csv"
ECOMMERCE_ADS_CSV="data/samples/aurora-cup-ads.csv"
ECOMMERCE_INVENTORY_CSV="data/samples/aurora-cup-inventory.csv"
ECOMMERCE_CUSTOMER_VOICES_CSV="data/samples/aurora-cup-customer-voices.csv"

# Observability
LOG_LEVEL="info"
SENTRY_DSN=""
